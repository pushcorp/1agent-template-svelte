{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "mcp__acp__Write",
      "mcp__acp__Edit",
      "mcp__acp__Bash",
      "Bash(ls:*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "WebSearch",
      "WebFetch(domain:support.google.com)",
      "Bash(npx svelte-check:*)",
      "Bash(wc:*)",
      "Bash(npx tsc:*)",
      "Bash(npm install:*)",
      "Read(./.claude/**)",
      "Read(~/.claude/**)",
      "Bash(npx tsx:*)",
      "Bash(npm ls:*)",
      "Bash(npx biome:*)"
    ],
    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./.dev.vars)",
      "Edit(./.env)",
      "Edit(./.env.*)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(~/.config/gcloud/**)",
      "Bash(rm -rf *)"
    ]
  },
  "alwaysThinkingEnabled": true,
  "spinnerVerbs": {
    "mode": "replace",
    "verbs": ["かんがえちゅう"]
  },
  "spinnerTipsEnabled": false,
  "plansDirectory": ".claude/plans",
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "env": {
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "40",
    "CLAUDE_CODE_DISABLE_FAST_MODE": "1",
    "CLAUDE_CODE_EFFORT_LEVEL": "high",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_HIDE_ACCOUNT_INFO": "1",
    "CLAUDE_CODE_IDE_SKIP_AUTO_INSTALL": "1"
  }
}
